<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/barcodeView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/hintText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="64dp"
        android:text="Point camera at barcode"
        android:textColor="#AAFFFFFF"
        android:textSize="13sp"
        android:alpha="0.8" />

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@drawable/top_bar_bg">

        <TextView
            android:id="@+id/itemCountText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 items scanned"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/closeButton"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="✕"
            android:textColor="#DDFFFFFF"
            android:textSize="16sp"
            android:gravity="center"
            android:background="@drawable/rounded_circle_bg" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bottom_sheet_bg">

        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/drag_handle" />

        <TextView
            android:id="@+id/errorLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unknown barcode — add it to inventory first"
            android:textColor="#FFFF5252"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginTop="8dp" />

        <RelativeLayout
            android:id="@+id/productInfoLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="12dp"
            android:background="@drawable/qty_edit_bg"
            android:padding="14dp">

            <LinearLayout
                android:id="@+id/qtyRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_alignParentTop="true">

                <Button
                    android:id="@+id/navBackButton"
                    android:layout_width="36dp"
                    android:layout_height="40dp"
                    android:text="◀"
                    android:textSize="16sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#555555"
                    android:gravity="center"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/qtyMinusButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="−"
                    android:textSize="20sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#444444"
                    android:gravity="center"
                    android:layout_marginStart="4dp"
                    android:padding="0dp" />

                <EditText
                    android:id="@+id/qtyEditText"
                    android:layout_width="80dp"
                    android:layout_height="40dp"
                    android:text="1"
                    android:textSize="18sp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#88FFFFFF"
                    android:gravity="center"
                    android:inputType="number"
                    android:background="@drawable/qty_edit_bg"
                    android:padding="4dp"
                    android:layout_marginHorizontal="4dp" />

                <Button
                    android:id="@+id/qtyPlusButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="+"
                    android:textSize="20sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#FF2E7D32"
                    android:gravity="center"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/navForwardButton"
                    android:layout_width="36dp"
                    android:layout_height="40dp"
                    android:text="▶"
                    android:textSize="16sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#555555"
                    android:gravity="center"
                    android:layout_marginStart="4dp"
                    android:padding="0dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/productDetailsColumn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/qtyRow"
                android:layout_toStartOf="@+id/barcodeContainer"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/productNameLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:ellipsize="marquee"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:scrollHorizontally="true"
                    android:textColor="@android:color/white"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/productPriceLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAFFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/productStockLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAFFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="3dp" />

                <TextView
                    android:id="@+id/productCategoryLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAFFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/barcodeContainer"
                android:layout_width="170dp"
                android:layout_height="0dp"
                android:layout_alignParentEnd="true"
                android:layout_below="@id/qtyRow"
                android:layout_alignBottom="@id/productDetailsColumn"
                android:minHeight="120dp"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/barcodeImage"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"
                    android:minHeight="80dp" />

                <TextView
                    android:id="@+id/barcodeNumberText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:textColor="#DDFFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>
        </RelativeLayout>

        <Button
            android:id="@+id/rescanButton"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Rescan This Item"
            android:textColor="#DDFFFFFF"
            android:textSize="13sp"
            android:background="@drawable/qty_edit_bg"
            android:visibility="gone"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/scanNextButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Scan Next Item"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/primary_rounded_btn"
            android:layout_marginTop="14dp" />

        <Button
            android:id="@+id/doneButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Done"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/success_rounded_btn"
            android:layout_marginTop="10dp" />
    </LinearLayout>
</RelativeLayout>
